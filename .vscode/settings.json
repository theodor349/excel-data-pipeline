{
  "files.exclude": {
    "**/.pytest_cache": true,
    "**/.venv": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/pyproject.toml": true,
    "**/uv.lock": true,
    "**/venv": true
  },
  "workbench.editor.customLabels.enabled": true,
  "workbench.editor.customLabels.patterns": {
    "**/queries/*/query.py": "${dirname}/query.py",
    "**/queries/*/test.py": "${dirname}/test.py"
  }
}
